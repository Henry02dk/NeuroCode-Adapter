{
    "version": "2.0.0",
    "tasks": [
      {
        "type": "npm",
        "script": "watch",
        "problemMatcher": "$tsc-watch",
        "isBackground": true,
        "presentation": {
          "reveal": "never"
        },
        "group": {
          "kind": "build",
          "isDefault": true
        }
      },
      {
        "type": "npm",
        "script": "compile",
        "group": "build",
        "problemMatcher": []
      },
      {
        "type": "npm",
        "script": "package",
        "group": "build",
        "problemMatcher": []
      },
      {
        "label": "Start MCP Server",
        "type": "shell",
        "command": "node",
        "args": [
          "${workspaceFolder}/dist/mcp/server.js"
        ],
        "isBackground": true,
        "problemMatcher": []
      }
    ]
  }