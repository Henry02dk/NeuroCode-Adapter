{
  "name": "neurocode-adapter",
  "displayName": "neurocode-adapter",
  "description": "Adaptive neurodiverse learning support",
  "version": "0.0.1",
  "engines": {
    "vscode": "^1.109.0"
  },
  "categories": [
    "Other"
  ],
  "activationEvents": [],
  "main": "./dist/extension.js",
  "contributes": {
    "commands": [
      {
        "command": "neurocode-adapter.activateAdapter",
        "title": "NeuroCode: Activate Adapter"
      },
      {
        "command": "neurocode-adapter.selectProfile",
        "title": "NeuroCode: Select Profile"
      },
      {
        "command": "neurocode-adapter.showProfile",
        "title": "NeuroCode: Show Profile"
      },
      {
        "command": "neurocode-adapter.readContext",
        "title": "NeuroCode: Read Assignment Context"
      },
      {
        "command": "neurocode-adapter.adaptAssignment",
        "title": "NeuroCode: Adapt Assignment"
      },
      {
        "command": "neurocode-adapter.showPrompt",
        "title": "NeuroCode: Show Prompt"
      }
    ],
    "configuration": {
      "title": "NeuroCode Adapter",
      "properties": {
        "neurocode.profile": {
          "type": "string",
          "default": "neurotypical",
          "enum": [
            "neurotypical",
            "dyslexia",
            "adhd",
            "autism"
          ],
          "description": "User neurodiversity learning profile"
        }
      }
    },
    "viewsContainers": {
      "activitybar": [
        {
          "id": "neurocode",
          "title": "NeuroCode",
          "icon": "media/icon.png"
        }
      ]
    },

    "views": {
      "neurocode": [
        {
          "type": "webview",
          "id": "neurocodeView",
          "name": "Adaptive Assignment"
        }
      ]
    }
  },
  "scripts": {
    "vscode:prepublish": "npm run package",
    "compile": "webpack",
    "watch": "webpack --watch",
    "package": "webpack --mode production --devtool hidden-source-map",
    "compile-tests": "tsc -p . --outDir out",
    "watch-tests": "tsc -p . -w --outDir out",
    "pretest": "npm run compile-tests && npm run compile && npm run lint",
    "lint": "eslint src",
    "test": "vscode-test"
  },
  "devDependencies": {
    "@types/mocha": "^10.0.10",
    "@types/node": "22.x",
    "@types/vscode": "^1.109.0",
    "@vscode/test-cli": "^0.0.12",
    "@vscode/test-electron": "^2.5.2",
    "eslint": "^9.39.3",
    "ts-loader": "^9.5.4",
    "typescript": "^5.9.3",
    "typescript-eslint": "^8.56.1",
    "webpack": "^5.105.3",
    "webpack-cli": "^6.0.1"
  },
  "dependencies": {
    "node-fetch": "^3.3.2"
  }
}
